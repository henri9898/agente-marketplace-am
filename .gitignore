# ============================================================
# Agente Marketplace AM — .gitignore
# ============================================================

# Dependências
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Variáveis de ambiente (NUNCA commitar — contém client_secret + tokens)
.env
.env.local
.env.*.local

# Dados de usuários locais (auth persistente em disco)
users.json

# Persistência de tokens OAuth (ML + Bling) — NUNCA commitar
tokens.json

# SQLite local (gerado em runtime — FASE 1 anti-duplicidade)
dados.sqlite
dados.sqlite-shm
dados.sqlite-wal

# Logs
*.log
logs/

# Cache de IDE/OS
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo

# Node e build
dist/
build/
coverage/
.cache/

# Claude Code
.claude/

# Scripts de setup com segredos embutidos (ML_CLIENT_SECRET)
deploy/vps-setup.sh

# Local Netlify folder
.netlify
