# Copie para .env e preencha.
# Pegue em https://developers.mercadolibre.com.br/devcenter
ML_CLIENT_ID=
ML_CLIENT_SECRET=
ML_REDIRECT_URI=http://localhost:3000/callback

# Preenchidos automaticamente após o primeiro login em /login
ML_ACCESS_TOKEN=
ML_REFRESH_TOKEN=
ML_USER_ID=
ML_TOKEN_EXPIRES_AT=

# ---------------------------------------------------------------
# BLING ERP (do cliente)
# Crie o app em: https://developer.bling.com.br → Meus aplicativos
# redirect_uri precisa bater com o configurado no app
# ---------------------------------------------------------------
BLING_CLIENT_ID=
BLING_CLIENT_SECRET=
BLING_REDIRECT_URI=http://localhost:3000/callback/bling
